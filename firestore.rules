rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "jskjageer@gmail.com" ||
         request.auth.token.email == "kalimdon07@gmail.com" ||
         request.auth.token.email == "admin@gmail.com");
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ── Cars Collection ─────────────────────────────────────────────────
    match /cars/{carId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // ── Dealers Collection ──────────────────────────────────────────────
    match /dealers/{dealerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Submissions Collection ──────────────────────────────────────────
    match /submissions/{submissionId} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Repairs / Showcase Collection ────────────────────────────────────
    match /repairs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Users Collection ───────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // ── Products Collection ─────────────────────────────────────────────
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Product Submissions ─────────────────────────────────────────────
    match /product_submissions/{docId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.submittedBy == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Orders Collection ───────────────────────────────────────────────
    match /orders/{orderId} {
      // Allow authenticated users to read and write orders
      allow read, write: if isAuthenticated();
      // Only admins can delete
      allow delete: if isAdmin();
    }

    // ── Cart Collection ─────────────────────────────────────────────────
    match /cart/{userId}/items/{itemId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // ── Appointments (Contact form) ──────────────────────────────────────
    match /appointments/{appointmentId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }
  }
}
